{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowLocal",
  "version": "0.1.0",
  "identifier": "com.flowlocal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FlowLocal",
        "url": "index.html",
        "width": 960,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "focus": true
      },
      {
        "label": "overlay",
        "title": "FlowLocal Overlay",
        "url": "index.html#overlay",
        "width": 460,
        "height": 88,
        "minWidth": 460,
        "minHeight": 88,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      }
    ],
    "trayIcon": {
      "id": "flowlocal-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "FlowLocal — Local Voice Dictation"
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }

    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3", "libayatana-appindicator3-1"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "openssl", "libayatana-appindicator"]
      }
    }
  },
  "plugins": {
    "global-shortcut": null,
    "autostart": null
  }
}

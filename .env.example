# ===================================================
# FlowLocal — Environment Configuration
# Copy this to .env and adjust for your system
# ===================================================

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=auto          # auto | cuda | cpu
WHISPER_COMPUTE_TYPE=auto    # auto | float16 | int8

# VAD
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=1500

# IPC
# Windows: named pipe paths
WHISPER_PIPE=\\.\pipe\flowlocal-whisper
LLM_PIPE=\\.\pipe\flowlocal-llm
RAG_PIPE=\\.\pipe\flowlocal-rag

# Linux: Unix socket paths
# WHISPER_SOCKET=/tmp/flowlocal-whisper.sock
# LLM_SOCKET=/tmp/flowlocal-llm.sock
# RAG_SOCKET=/tmp/flowlocal-rag.sock

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# SQLite
DATABASE_PATH=./data/db/flowlocal.db

# Logging
RUST_LOG=info
PYTHON_LOG_LEVEL=INFO

# Dev
DEV_MODE=false
